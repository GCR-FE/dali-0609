<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post-Meeting Report – {{ customer_name }} | {{ meeting_title }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { font-size: 9px; }
        body {
            font-family: 'Inter', 'Noto Sans SC', -apple-system, sans-serif;
            color: #1a1a1a;
            background: #fff;
            max-width: 820px;
            margin: 0 auto;
            padding: 20px 28px;
            line-height: 1.5;
        }

        h1 { font-size: 18px; font-weight: 700; margin-bottom: 2px; }
        h2 { font-size: 13px; font-weight: 700; color: #1a1a1a; margin: 14px 0 6px 0; padding-bottom: 3px; border-bottom: 1.5px solid #e0e0e0; }
        h3 { font-size: 11px; font-weight: 600; color: #333; margin: 10px 0 4px 0; }

        .header-meta { font-size: 10px; color: #555; margin-bottom: 14px; }
        .header-meta span { margin-right: 12px; }

        .badge {
            display: inline-block;
            font-size: 9px;
            font-weight: 600;
            padding: 1px 7px;
            border-radius: 3px;
            vertical-align: middle;
        }
        .badge-achieved { background: #c8e6c9; color: #1b5e20; }
        .badge-partial { background: #fff9c4; color: #f57f17; }
        .badge-not-achieved { background: #ffcdd2; color: #b71c1c; }
        .badge-sponsor { background: #c8e6c9; color: #1b5e20; }
        .badge-supporter { background: #c8e6c9; color: #1b5e20; }
        .badge-neutral { background: #fff9c4; color: #f57f17; }
        .badge-non-supporter { background: #ffcdd2; color: #b71c1c; }
        .badge-adversary { background: #ffcdd2; color: #b71c1c; }
        .badge-answered { background: #c8e6c9; color: #1b5e20; }
        .badge-unanswered { background: #ffcdd2; color: #b71c1c; }
        .badge-high { background: #ffcdd2; color: #b71c1c; }
        .badge-medium { background: #fff9c4; color: #f57f17; }
        .badge-low { background: #f5f5f5; color: #555; }
        .badge-update { background: #e8eaf6; color: #283593; }
        .badge-add { background: #c8e6c9; color: #1b5e20; }
        .badge-remove { background: #ffcdd2; color: #b71c1c; }

        table { width: 100%; border-collapse: collapse; font-size: 10px; margin: 4px 0 8px 0; }
        th { font-size: 9px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.3px; padding: 4px 6px; border-bottom: 1px solid #ddd; text-align: left; }
        td { padding: 4px 6px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }

        .stage-box {
            border-radius: 4px;
            padding: 5px 10px;
            font-size: 10px;
            font-weight: 600;
            margin: 6px 0;
            display: inline-block;
        }
        .stage-achieved { background: #e8f5e9; color: #2e7d32; }
        .stage-not-achieved { background: #fff8e1; color: #f57f17; }

        .recommendation-box {
            background: #f0f4ff;
            border-left: 3px solid #1565c0;
            border-radius: 0 4px 4px 0;
            padding: 8px 10px;
            margin-top: 8px;
            font-size: 9.5px;
            color: #333;
            line-height: 1.5;
        }

        .fallback-box {
            background: #f8f9fa;
            border: 1px solid #e8e8e8;
            border-radius: 4px;
            padding: 6px 10px;
            margin: 6px 0;
            font-size: 9.5px;
            color: #444;
        }

        .email-box {
            background: #faf4ff;
            border: 1px solid #e0d4f0;
            border-radius: 4px;
            padding: 8px 10px;
            margin-top: 6px;
            font-size: 9.5px;
            color: #444;
        }

        .footer { text-align: center; font-size: 9px; color: #999; margin-top: 16px; padding-top: 8px; border-top: 1px solid #eee; }

        @media print {
            body { padding: 12px 16px; }
            h2, h3 { break-after: avoid; }
            table { break-inside: auto; }
            tr { break-inside: avoid; }
            .recommendation-box { break-inside: avoid; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div style="font-size: 9px; font-weight: 700; letter-spacing: 1.5px; color: #888; text-transform: uppercase; margin-bottom: 4px;">POST-MEETING REPORT</div>
    <h1>{{ meeting_title }}</h1>
    <div class="header-meta">
        <span><strong>Customer:</strong> {{ customer_name }}</span>
        <span><strong>Date:</strong> {{ meeting_date }}</span>
        <span><strong>Recorded by:</strong> {{ recorded_by }}</span>
        <span><strong>Related:</strong> {{ related_document }}</span>
    </div>

    <!-- Section 1: Outcome Assessment -->
    <h2>Outcome Assessment</h2>
    <table>
        <thead><tr><th>#</th><th>Target Meeting Outcome</th><th>Result</th><th>Evidence & Notes</th></tr></thead>
        <tbody>
            {% for outcome in outcome_results %}
            <tr>
                <td>{{ outcome.number }}</td>
                <td>{{ outcome.target_outcome }}</td>
                <td>
                    {% if outcome.result == "achieved" %}
                    <span class="badge badge-achieved">Achieved</span>
                    {% elif outcome.result == "partial" %}
                    <span class="badge badge-partial">Partial</span>
                    {% else %}
                    <span class="badge badge-not-achieved">Not Achieved</span>
                    {% endif %}
                </td>
                <td>{{ outcome.evidence }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if fallback_outcome_assessment %}
    <div class="fallback-box"><strong>Fallback Outcome:</strong> {{ fallback_outcome_assessment }}</div>
    {% endif %}

    {% if stage_progression %}
    <div class="stage-box {% if stage_progression.achieved %}stage-achieved{% else %}stage-not-achieved{% endif %}">
        Stage: {{ stage_progression.planned }}
        {% if stage_progression.achieved %} — Achieved{% else %} — Actual: {{ stage_progression.actual }}{% endif %}
    </div>
    {% endif %}

    <!-- Section 2: Meeting Insights -->
    <h2>Meeting Insights</h2>

    <h3>Customer Sentiment</h3>
    <table>
        <thead><tr><th>Attendee</th><th>Before</th><th></th><th>After</th><th>Evidence</th></tr></thead>
        <tbody>
            {% for s in sentiment_changes %}
            <tr>
                <td style="font-weight: 600;">{{ s.attendee }}</td>
                <td><span class="badge badge-{{ s.stance_before|lower|replace(' ', '-')|replace('_', '-') }}">{{ s.stance_before }}</span></td>
                <td style="text-align: center;">→</td>
                <td><span class="badge badge-{{ s.stance_after|lower|replace(' ', '-')|replace('_', '-') }}">{{ s.stance_after }}</span></td>
                <td>{{ s.evidence }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <h3>Key Findings</h3>
    <table>
        <thead><tr><th>Finding</th><th>Source</th><th>Implication</th></tr></thead>
        <tbody>
            {% for f in key_findings %}
            <tr>
                <td style="font-weight: 600;">{{ f.finding }}</td>
                <td>{{ f.source }}</td>
                <td>{{ f.implication }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if info_gap_check %}
    <h3>Information Gap Check</h3>
    <table>
        <thead><tr><th>Question (from Call Plan)</th><th>Status</th><th>Answer / Notes</th></tr></thead>
        <tbody>
            {% for q in info_gap_check %}
            <tr>
                <td>{{ q.question }}</td>
                <td><span class="badge badge-{{ q.status }}">{% if q.status == "answered" %}Answered{% else %}Gap{% endif %}</span></td>
                <td>{{ q.answer_notes }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    <!-- Section 3: What Changed — EP Update -->
    <h2>What Changed — EP Update</h2>
    <table>
        <thead><tr><th>EP Section</th><th>Change</th><th>What to Write</th></tr></thead>
        <tbody>
            {% for update in ep_updates %}
            <tr>
                <td style="font-weight: 600;">{{ update.section }}</td>
                <td><span class="badge badge-{{ update.change_type|lower }}">{{ update.change_type }}</span></td>
                <td>{{ update.what_to_write }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if execution_log_update %}
    <div class="fallback-box"><strong>Execution Log:</strong> {{ execution_log_update }}</div>
    {% endif %}

    {% if agent_recommendation %}
    <div class="recommendation-box">
        <strong>Agent Recommendation:</strong><br>{{ agent_recommendation }}
    </div>
    {% endif %}

    <!-- Section 4: Next Steps — Planned vs Actual -->
    <h2>Next Steps — Planned vs Actual</h2>
    <table>
        <thead><tr><th>#</th><th>Planned (from CP)</th><th>Actual Agreed</th><th>Delta</th></tr></thead>
        <tbody>
            {% set max_steps = [planned_next_steps|length, actual_next_steps|length] | max %}
            {% for i in range(max_steps) %}
            <tr>
                <td>{{ i + 1 }}</td>
                <td>{% if i < planned_next_steps|length %}{{ planned_next_steps[i].step }} ({{ planned_next_steps[i].owner }}, {{ planned_next_steps[i].timeline }}){% else %}<em style="color: #999;">—</em>{% endif %}</td>
                <td>{% if i < actual_next_steps|length %}{{ actual_next_steps[i].step }} ({{ actual_next_steps[i].owner }}, {{ actual_next_steps[i].timeline }}){% else %}<em style="color: #999;">— Dropped —</em>{% endif %}</td>
                <td>{% if i < actual_next_steps|length %}{{ actual_next_steps[i].delta }}{% elif i < planned_next_steps|length %}Not pursued{% endif %}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if action_items %}
    <h3>Action Items</h3>
    <table>
        <thead><tr><th>Priority</th><th>Action</th><th>Owner</th><th>ETA</th><th>Status</th></tr></thead>
        <tbody>
            {% for item in action_items %}
            <tr>
                <td><span class="badge badge-{{ item.priority|lower }}">{{ item.priority }}</span></td>
                <td style="font-weight: 600;">{{ item.action }}</td>
                <td>{{ item.owner }}</td>
                <td style="white-space: nowrap;">{{ item.eta }}</td>
                <td>{{ item.status }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    <!-- Section 5: Customer Recap Email Draft -->
    {% if recap_email %}
    <h2>Customer Recap Email Draft</h2>
    <div class="email-box">
        <div style="font-size: 9px; font-weight: 600; color: #666; margin-bottom: 6px;">Subject: {{ recap_email.subject }}</div>
        <div style="white-space: pre-line; line-height: 1.6;">{{ recap_email.body }}</div>
    </div>
    {% endif %}

    <!-- Footer -->
    <div class="footer">Last updated: {{ last_updated }}</div>

</body>
</html>
