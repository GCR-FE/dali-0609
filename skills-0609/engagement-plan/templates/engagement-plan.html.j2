<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Engagement Plan – {{ customer_name }} | {{ opportunity_name }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', 'Noto Sans SC', -apple-system, sans-serif;
            font-size: 13px;
            line-height: 1.5;
            color: #1a1a1a;
            background: #fff;
            padding: 24px 32px;
            max-width: 960px;
            margin: 0 auto;
        }

        h1 { font-size: 22px; font-weight: 700; margin-bottom: 2px; }
        h2 { font-size: 15px; font-weight: 600; color: #5b21b6; margin: 20px 0 8px 0; padding-bottom: 4px; border-bottom: 2px solid #ede9fe; }
        h3 { font-size: 13px; font-weight: 600; color: #374151; margin: 12px 0 4px 0; }

        .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid #e5e7eb; }
        .header-left .subtitle { font-size: 12px; color: #6b7280; }
        .deal-value { background: #ede9fe; color: #5b21b6; font-weight: 600; font-size: 14px; padding: 6px 14px; border-radius: 6px; }

        /* Snapshot grid */
        .snapshot-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin: 8px 0; }
        .snapshot-item { background: #f9fafb; border: 1px solid #f3f4f6; border-radius: 6px; padding: 8px 10px; }
        .snapshot-item .label { font-size: 10px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; }
        .snapshot-item .value { font-size: 12px; font-weight: 500; color: #1a1a1a; margin-top: 2px; }

        /* Content blocks */
        .content-block { margin: 8px 0; }
        .content-block p { font-size: 12px; color: #374151; line-height: 1.6; }
        .content-block .block-label { font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 2px; }

        /* Strategy row */
        .strategy-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 8px 0; }

        /* Progress stepper */
        .stepper { display: flex; align-items: center; gap: 0; margin: 10px 0; padding: 10px 0; }
        .stepper-stage { display: flex; flex-direction: column; align-items: center; flex: 1; }
        .stepper-dot { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 600; }
        .stepper-dot.done { background: #16a34a; color: white; }
        .stepper-dot.active { background: #7c3aed; color: white; box-shadow: 0 0 0 3px rgba(124,58,237,0.15); }
        .stepper-dot.upcoming { background: #f3f4f6; color: #9ca3af; border: 1.5px solid #d1d5db; }
        .stepper-label { font-size: 9px; margin-top: 3px; color: #6b7280; font-weight: 500; }
        .stepper-line { height: 2px; flex: 1; min-width: 16px; }
        .stepper-line.done { background: #16a34a; }
        .stepper-line.upcoming { background: #e5e7eb; }

        /* Stakeholder cards */
        .stakeholder { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; margin-bottom: 8px; }
        .stakeholder-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
        .stakeholder-name { font-size: 13px; font-weight: 600; }
        .stakeholder-title { font-size: 11px; color: #6b7280; }
        .stakeholder-fields { display: grid; grid-template-columns: 1fr; gap: 3px; }
        .stakeholder-field { font-size: 11px; line-height: 1.5; color: #374151; }
        .stakeholder-field strong { color: #1a1a1a; font-weight: 600; }
        .how-to-win { background: #f9fafb; border-radius: 4px; padding: 6px 8px; margin-top: 6px; font-size: 11px; color: #374151; }

        /* Pill badges */
        .pill { display: inline-block; font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 10px; }
        .pill-sponsor, .pill-supporter, .pill-champion { background: #dcfce7; color: #166534; }
        .pill-neutral { background: #fef9c3; color: #a16207; }
        .pill-non-supporter, .pill-adversary { background: #fee2e2; color: #991b1b; }

        /* Metro roadmap */
        .metro { position: relative; padding-left: 28px; margin: 8px 0; }
        .metro::before { content: ''; position: absolute; left: 9px; top: 0; bottom: 0; width: 3px; background: #e5e7eb; border-radius: 2px; }
        .metro-progress { position: absolute; left: 9px; top: 0; width: 3px; background: #7c3aed; border-radius: 2px; }
        .metro-item { position: relative; padding: 6px 0; }
        .metro-dot { position: absolute; left: -23px; top: 10px; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 8px; font-weight: 700; }
        .metro-dot.done { background: #16a34a; color: white; }
        .metro-dot.active { background: #7c3aed; color: white; }
        .metro-dot.planned { background: white; border: 2px solid #d1d5db; color: #9ca3af; }
        .metro-card { border: 1px solid #e5e7eb; border-radius: 6px; padding: 8px 10px; }
        .metro-item.is-active .metro-card { border-color: #7c3aed; background: #faf5ff; }
        .metro-card-title { font-size: 11px; font-weight: 500; color: #1a1a1a; }
        .metro-card-meta { display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap; }
        .metro-meta-tag { font-size: 10px; color: #6b7280; background: #f3f4f6; padding: 1px 6px; border-radius: 4px; }
        .metro-status { font-size: 9px; font-weight: 600; padding: 1px 6px; border-radius: 4px; }
        .metro-status.done { background: #dcfce7; color: #166534; }
        .metro-status.next { background: #ede9fe; color: #5b21b6; }
        .metro-status.planned { background: #f3f4f6; color: #6b7280; }
        .metro-endpoint { margin-top: 8px; padding: 6px 10px; background: #dcfce7; border-radius: 6px; font-size: 11px; color: #166534; font-weight: 500; }

        /* Risk tables */
        .risk-item { border: 1px solid #e5e7eb; border-radius: 6px; padding: 8px 10px; margin-bottom: 6px; }
        .risk-item.high { border-left: 3px solid #dc2626; }
        .risk-item.medium { border-left: 3px solid #f59e0b; }
        .risk-item p { font-size: 11px; line-height: 1.5; color: #374151; }
        .risk-item strong { color: #1a1a1a; }
        .risk-label { font-size: 9px; font-weight: 700; text-transform: uppercase; padding: 1px 6px; border-radius: 3px; display: inline-block; margin-bottom: 4px; }
        .risk-label.high { background: #fee2e2; color: #991b1b; }
        .risk-label.medium { background: #fef3c7; color: #92400e; }

        /* Estimate */
        .estimate-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 8px 0; }
        .estimate-box { background: #f9fafb; border: 1px solid #f3f4f6; border-radius: 6px; padding: 8px 12px; text-align: center; }
        .estimate-box .label { font-size: 10px; font-weight: 600; color: #6b7280; text-transform: uppercase; }
        .estimate-box .value { font-size: 12px; font-weight: 500; margin-top: 2px; }

        /* Next milestone */
        .next-milestone { border-left: 3px solid #7c3aed; padding-left: 12px; margin: 8px 0; }
        .nm-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 12px; margin: 6px 0; }
        .nm-item .label { font-size: 10px; font-weight: 600; color: #6b7280; text-transform: uppercase; }
        .nm-item .value { font-size: 12px; color: #1a1a1a; margin-top: 1px; }
        .attendee { background: #f9fafb; border-radius: 4px; padding: 6px 8px; margin-bottom: 4px; }
        .attendee-name { font-size: 11px; font-weight: 600; color: #1a1a1a; }
        .attendee-outcome { font-size: 11px; color: #374151; margin-top: 1px; }
        .question-item { font-size: 11px; color: #374151; padding: 4px 0; border-bottom: 1px solid #f3f4f6; }
        .question-item:last-child { border-bottom: none; }

        /* Execution log */
        .log-entry { border: 1px solid #e5e7eb; border-radius: 6px; padding: 10px; margin-bottom: 8px; }
        .log-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
        .log-header .title { font-size: 12px; font-weight: 600; }
        .log-header .date { font-size: 11px; color: #6b7280; }
        .log-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
        .log-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; margin-top: 6px; }
        .log-field .label { font-size: 10px; font-weight: 600; color: #6b7280; text-transform: uppercase; }
        .log-field .value { font-size: 11px; color: #374151; margin-top: 1px; }

        .footer { text-align: center; font-size: 11px; color: #9ca3af; margin-top: 20px; padding-top: 12px; border-top: 1px solid #f3f4f6; }

        /* Print styles */
        @media print {
            @page { size: A4; margin: 10mm; }
            body { padding: 0; font-size: 11px; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .stakeholder, .metro-card, .risk-item, .log-entry, .attendee { break-inside: avoid; page-break-inside: avoid; }
            h2, h3, .block-label, .label-large, .log-header, .stakeholder-header { break-after: avoid; page-break-after: avoid; }
            h2 { margin-top: 14px; }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <div class="header-left">
            <div class="subtitle">ENGAGEMENT PLAN</div>
            <h1>{{ customer_name }}</h1>
            <div class="subtitle">{{ opportunity_name }}</div>
        </div>
        <div class="deal-value">{{ deal_value }}</div>
    </div>

    <!-- Opportunity Snapshot -->
    <h2>Opportunity Snapshot</h2>
    <div class="snapshot-grid">
        <div class="snapshot-item">
            <div class="label">Account</div>
            <div class="value">{{ customer_name }} · {{ industry }}</div>
        </div>
        <div class="snapshot-item">
            <div class="label">Stage</div>
            <div class="value">{{ current_stage }}</div>
        </div>
        <div class="snapshot-item">
            <div class="label">Target Launch</div>
            <div class="value">{{ target_launch_date }}</div>
        </div>
        <div class="snapshot-item">
            <div class="label">Customer Type</div>
            <div class="value">{{ customer_type }}</div>
        </div>
    </div>

    <!-- Why Now -->
    <div class="content-block">
        <div class="block-label">Why Now</div>
        <p>{{ why_now }}</p>
    </div>

    <!-- Deal Objective & Win Strategy -->
    <div class="strategy-row">
        <div class="content-block">
            <div class="block-label">Deal Objective</div>
            <p>{{ deal_objective }}</p>
        </div>
        <div class="content-block">
            <div class="block-label">Win Strategy</div>
            <p>{{ win_strategy }}</p>
        </div>
    </div>
    {% if key_risks %}
    <div class="content-block">
        <div class="block-label" style="color: #dc2626;">Key Risks</div>
        <p>{{ key_risks }}</p>
    </div>
    {% endif %}

    <!-- Engagement Progress -->
    <h2>Engagement Progress</h2>
    <div class="stepper">
        {% set stages = ["Prospect", "Qualified", "Tech Val", "Biz Val", "Committed", "Closed"] %}
        {% for stage in stages %}
        {% if not loop.first %}
        <div class="stepper-line {% if loop.index0 <= current_stage_index %}done{% else %}upcoming{% endif %}"></div>
        {% endif %}
        <div class="stepper-stage">
            {% if loop.index0 < current_stage_index %}
            <div class="stepper-dot done">✓</div>
            {% elif loop.index0 == current_stage_index %}
            <div class="stepper-dot active">●</div>
            {% else %}
            <div class="stepper-dot upcoming">○</div>
            {% endif %}
            <div class="stepper-label">{{ stage }}</div>
        </div>
        {% endfor %}
    </div>

    <!-- Key Stakeholders -->
    <h2>Key Stakeholders</h2>
    {% for person in stakeholders %}
    <div class="stakeholder">
        <div class="stakeholder-header">
            <div>
                <span class="stakeholder-name">{{ person.name }}</span>
                <span class="stakeholder-title"> · {{ person.title }}</span>
            </div>
            <span class="pill pill-{{ person.stance|lower|replace(' ', '-')|replace('_', '-') }}">{{ person.stance }}</span>
        </div>
        <div class="stakeholder-fields">
            <div class="stakeholder-field"><strong>Priority:</strong> {{ person.engagement_priority }}</div>
            <div class="stakeholder-field"><strong>Role:</strong> {{ person.role_in_deal }}</div>
            <div class="stakeholder-field"><strong>What They Care About:</strong> {{ person.what_they_care_about }}</div>
            <div class="stakeholder-field"><strong>What We Need:</strong> {{ person.what_we_need }}</div>
        </div>
        {% if person.how_to_win %}
        <div class="how-to-win"><strong>How to Win:</strong> {{ person.how_to_win }}</div>
        {% endif %}
    </div>
    {% endfor %}

    <!-- Engagement Roadmap -->
    <h2>Engagement Roadmap</h2>
    {% set done_count = roadmap | selectattr('status', 'equalto', 'Done') | list | length %}
    <div style="font-size: 11px; color: #6b7280; margin-bottom: 4px;">{{ done_count }}/{{ roadmap | length }} stations complete</div>
    <div class="metro">
        {% set total = roadmap | length %}
        {% if total > 0 %}
        <div class="metro-progress" style="height: {{ (done_count / total * 100) | round }}%;"></div>
        {% endif %}
        {% for milestone in roadmap %}
        <div class="metro-item {% if milestone.status == 'Next' %}is-active{% endif %}">
            {% if milestone.status == "Done" %}
            <div class="metro-dot done">✓</div>
            {% elif milestone.status == "Next" %}
            <div class="metro-dot active">{{ loop.index }}</div>
            {% else %}
            <div class="metro-dot planned">{{ loop.index }}</div>
            {% endif %}
            <div class="metro-card">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span class="metro-card-title">{{ milestone.description }}</span>
                    {% if milestone.status == "Done" %}
                    <span class="metro-status done">Done</span>
                    {% elif milestone.status == "Next" %}
                    <span class="metro-status next">Next</span>
                    {% else %}
                    <span class="metro-status planned">Planned</span>
                    {% endif %}
                </div>
                <div class="metro-card-meta">
                    {% if milestone.key_stakeholders %}
                    <span class="metro-meta-tag">👤 {{ milestone.key_stakeholders }}</span>
                    {% endif %}
                    {% if milestone.aws_team %}
                    <span class="metro-meta-tag">☁️ {{ milestone.aws_team }}</span>
                    {% endif %}
                    {% if milestone.target_window %}
                    <span class="metro-meta-tag">📅 {{ milestone.target_window }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
        {% if deal_objective %}
        <div class="metro-endpoint">🏁 {{ deal_objective }}</div>
        {% endif %}
    </div>

    <!-- Estimate & Contingency -->
    <h2>Estimate & Contingency</h2>
    <div class="estimate-grid">
        <div class="estimate-box">
            <div class="label">Best Case</div>
            <div class="value">{{ estimate_best_milestones }} milestones · {{ estimate_best_timeline }}</div>
        </div>
        <div class="estimate-box">
            <div class="label">Worst Case</div>
            <div class="value">{{ estimate_worst_milestones }} milestones · {{ estimate_worst_timeline }}</div>
        </div>
    </div>

    {% if stakeholder_risks %}
    <h3>Stakeholder Risk & Leverage</h3>
    {% for risk in stakeholder_risks %}
    <div class="risk-item medium">
        <p><strong>{{ risk.stakeholder }}</strong></p>
        <p><strong>Red Flag:</strong> {{ risk.red_flag }}</p>
        <p><strong>Leverage:</strong> {{ risk.leverage_source }}</p>
        <p><strong>Plan B:</strong> {{ risk.plan_b }}</p>
    </div>
    {% endfor %}
    {% endif %}

    {% if milestone_risks %}
    <h3>Milestone Risk & Contingency</h3>
    {% for risk in milestone_risks %}
    <div class="risk-item {{ risk.severity }}">
        <span class="risk-label {{ risk.severity }}">{{ risk.severity|upper }}</span>
        <p><strong>{{ risk.milestone }} — {{ risk.risk_item }}</strong></p>
        <p><strong>Trigger:</strong> {{ risk.trigger }}</p>
        <p><strong>Impact:</strong> {{ risk.impact }}</p>
        <p><strong>Plan B:</strong> {{ risk.plan_b }}</p>
    </div>
    {% endfor %}
    {% endif %}

    <!-- Next Milestone Detail -->
    <h2>Next Milestone: {{ next_milestone.title }}</h2>
    <div class="next-milestone">
        <div class="nm-grid">
            <div class="nm-item">
                <div class="label">Target Date</div>
                <div class="value">{{ next_milestone.target_date }}</div>
            </div>
            <div class="nm-item">
                <div class="label">AWS Team</div>
                <div class="value">{{ next_milestone.aws_team }}</div>
            </div>
        </div>
        <div style="margin-top: 6px;">
            <div class="label" style="font-size: 10px; font-weight: 600; color: #6b7280; text-transform: uppercase;">Objective</div>
            <div style="font-size: 12px; color: #1a1a1a; margin-top: 1px;">{{ next_milestone.objective }}</div>
        </div>

        <h3>Customer Attendees & Target Outcomes</h3>
        {% for attendee in next_milestone.attendees %}
        <div class="attendee">
            <div class="attendee-name">{{ attendee.name }} ({{ attendee.title }})</div>
            <div class="attendee-outcome">{{ attendee.target_outcome }}</div>
        </div>
        {% endfor %}

        {% if next_milestone.key_questions %}
        <h3>Key Questions</h3>
        {% for question in next_milestone.key_questions %}
        <div class="question-item">{{ loop.index }}. {{ question }}</div>
        {% endfor %}
        {% endif %}
    </div>

    <!-- Execution Log -->
    {% if execution_log %}
    <h2>Execution Log</h2>
    {% for entry in execution_log %}
    <div class="log-entry">
        <div class="log-header">
            <span class="title">Engagement #{{ entry.number }}</span>
            <span class="date">{{ entry.date }} · {{ entry.attendees }}</span>
        </div>
        <div class="log-grid">
            <div class="log-field">
                <div class="label">Planned</div>
                <div class="value">{{ entry.planned }}</div>
            </div>
            <div class="log-field">
                <div class="label">Actual</div>
                <div class="value">{{ entry.actual }}</div>
            </div>
        </div>
        <div class="log-grid-3">
            <div class="log-field">
                <div class="label">People Updates</div>
                <div class="value">{{ entry.people_updates }}</div>
            </div>
            <div class="log-field">
                <div class="label">Key Learnings</div>
                <div class="value">{{ entry.key_learnings }}</div>
            </div>
            <div class="log-field">
                <div class="label">Plan Adjustment</div>
                <div class="value">{{ entry.plan_adjustment }}</div>
            </div>
        </div>
    </div>
    {% endfor %}
    {% endif %}

    <div class="footer">Generated by AWS Sales Agent · Last updated: {{ last_updated }}</div>
</body>
</html>
