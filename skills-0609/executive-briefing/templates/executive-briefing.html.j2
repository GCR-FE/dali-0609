<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Executive Briefing – {{ customer_name }} | {{ meeting_title }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { font-size: 9px; }
        body {
            font-family: 'Inter', 'Noto Sans SC', -apple-system, sans-serif;
            color: #1a1a1a;
            background: #fff;
            max-width: 820px;
            margin: 0 auto;
            padding: 20px 28px;
            line-height: 1.5;
        }

        h1 { font-size: 18px; font-weight: 700; margin-bottom: 2px; }
        h2 { font-size: 13px; font-weight: 700; color: #1a1a1a; margin: 14px 0 6px 0; padding-bottom: 3px; border-bottom: 1.5px solid #e0e0e0; }
        h3 { font-size: 11px; font-weight: 600; color: #333; margin: 10px 0 4px 0; }

        .confidential-banner {
            background: #ffebee;
            border: 1px solid #ef9a9a;
            border-radius: 4px;
            padding: 5px 12px;
            text-align: center;
            font-size: 10px;
            font-weight: 700;
            color: #c62828;
            letter-spacing: 0.5px;
            margin-bottom: 14px;
        }

        .header-meta { font-size: 10px; color: #555; margin-bottom: 14px; }
        .header-meta span { margin-right: 12px; }

        .badge {
            display: inline-block;
            font-size: 9px;
            font-weight: 600;
            padding: 1px 7px;
            border-radius: 3px;
            vertical-align: middle;
        }
        .badge-sponsor { background: #c8e6c9; color: #1b5e20; }
        .badge-supporter { background: #c8e6c9; color: #1b5e20; }
        .badge-neutral { background: #fff9c4; color: #f57f17; }
        .badge-non-supporter { background: #ffcdd2; color: #b71c1c; }
        .badge-adversary { background: #ffcdd2; color: #b71c1c; }
        .badge-champion { background: #c8e6c9; color: #1b5e20; }

        table { width: 100%; border-collapse: collapse; font-size: 10px; margin: 4px 0 8px 0; }
        th { font-size: 9px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.3px; padding: 4px 6px; border-bottom: 1px solid #ddd; text-align: left; }
        td { padding: 4px 6px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }

        .attendee-card {
            border: 1px solid #e8e8e8;
            border-radius: 4px;
            padding: 8px 10px;
            margin-bottom: 6px;
        }
        .attendee-name { font-size: 11px; font-weight: 600; }
        .attendee-title { font-size: 9.5px; color: #666; }
        .attendee-para { font-size: 9.5px; color: #444; margin-top: 4px; line-height: 1.5; }

        .context-box {
            background: #f8f9fa;
            border: 1px solid #e8e8e8;
            border-radius: 4px;
            padding: 8px 10px;
            margin: 6px 0;
            font-size: 9.5px;
            color: #444;
            line-height: 1.5;
        }

        .objective-block {
            border: 1px solid #e8e8e8;
            border-radius: 4px;
            padding: 8px 10px;
            margin-bottom: 8px;
        }
        .objective-title { font-size: 10.5px; font-weight: 600; color: #1a1a1a; margin-bottom: 4px; }
        .objective-detail { font-size: 9.5px; color: #444; margin-top: 3px; line-height: 1.45; }
        .objective-detail strong { color: #333; font-weight: 600; }

        .concern-block {
            border-left: 3px solid #f57f17;
            padding: 6px 10px;
            margin-bottom: 6px;
            background: #fffde7;
            border-radius: 0 4px 4px 0;
        }
        .concern-title { font-size: 10px; font-weight: 600; color: #5d4037; }
        .concern-detail { font-size: 9.5px; color: #555; margin-top: 2px; }

        .landmine-box {
            background: #fff5f5;
            border: 1px solid #ffcdd2;
            border-radius: 4px;
            padding: 6px 10px;
            margin-top: 6px;
            font-size: 9.5px;
            color: #c62828;
        }

        .next-steps-row { display: flex; gap: 10px; margin-bottom: 5px; align-items: flex-start; }
        .next-steps-label { font-size: 9px; font-weight: 700; min-width: 70px; padding: 2px 6px; border-radius: 3px; text-align: center; }
        .ns-ideal { background: #c8e6c9; color: #1b5e20; }
        .ns-acceptable { background: #fff9c4; color: #f57f17; }
        .ns-minimum { background: #f5f5f5; color: #555; }
        .next-steps-content { font-size: 9.5px; color: #444; flex: 1; }

        .account-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin: 6px 0; }
        .account-cell { background: #f8f9fa; border: 1px solid #e8e8e8; border-radius: 4px; padding: 5px 8px; text-align: center; }
        .account-cell-label { font-size: 8.5px; font-weight: 600; color: #666; text-transform: uppercase; }
        .account-cell-value { font-size: 10px; font-weight: 600; color: #1a1a1a; margin-top: 2px; }

        .company-profile {
            background: #f0f4ff;
            border: 1px solid #d0daf0;
            border-radius: 4px;
            padding: 8px 10px;
            margin-top: 8px;
            font-size: 9.5px;
            color: #333;
            line-height: 1.5;
        }

        .appendix-block {
            border: 1px solid #e8e8e8;
            border-radius: 4px;
            padding: 8px 10px;
            margin-bottom: 6px;
        }
        .appendix-title { font-size: 10px; font-weight: 600; color: #333; margin-bottom: 3px; }
        .appendix-content { font-size: 9.5px; color: #444; line-height: 1.5; white-space: pre-line; }

        .footer { text-align: center; font-size: 9px; color: #999; margin-top: 16px; padding-top: 8px; border-top: 1px solid #eee; }

        @media print {
            body { padding: 12px 16px; }
            h2, h3, .attendee-card, .objective-block, .concern-block, .appendix-block { break-after: avoid; }
            .attendee-card, .objective-block, .concern-block { break-inside: avoid; }
            .confidential-banner { background: #ffebee !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>

    <!-- Confidential Banner -->
    <div class="confidential-banner">INTERNAL USE ONLY — AWS Confidential</div>

    <!-- Header -->
    <div style="font-size: 9px; font-weight: 700; letter-spacing: 1.5px; color: #888; text-transform: uppercase; margin-bottom: 4px;">EXECUTIVE BRIEFING</div>
    <h1>{{ customer_name }}</h1>
    <div style="font-size: 11px; color: #444; margin-bottom: 6px;">{{ meeting_title }}</div>
    <div class="header-meta">
        <span><strong>Date:</strong> {{ meeting_date }} {{ meeting_time }}</span>
        <span><strong>Format:</strong> {{ meeting_format }}</span>
        <span><strong>Opportunity:</strong> {{ opportunity_name }}</span>
        <span><strong>Stage:</strong> {{ opp_stage }}</span>
    </div>

    <!-- Section 1: Meeting Logistics -->
    <h2>Meeting Logistics</h2>
    <div class="context-box">
        <strong>Who Requested & Why:</strong> {{ who_requested_and_why }}
    </div>
    <h3>AWS Team</h3>
    <table>
        <thead><tr><th>Name</th><th>Role</th><th>Purpose</th></tr></thead>
        <tbody>
            {% for person in aws_team %}
            <tr>
                <td style="font-weight: 600;">{{ person.name }}</td>
                <td>{{ person.role }}</td>
                <td>{{ person.purpose }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Section 2: Customer Attendee Background -->
    <h2>Customer Attendee Background</h2>
    {% for person in customer_attendees %}
    <div class="attendee-card">
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 3px;">
            <span class="attendee-name">{{ person.name }}</span>
            <span class="attendee-title">{{ person.title }}</span>
            <span class="badge badge-{{ person.stance|lower|replace(' ', '-')|replace('_', '-') }}">{{ person.stance }}</span>
        </div>
        <div class="attendee-para">{{ person.background_paragraph }}</div>
    </div>
    {% endfor %}

    {% if company_profile %}
    <div class="company-profile">
        <strong>Company Profile:</strong> {{ company_profile }}
    </div>
    {% endif %}

    <!-- Section 3: Meeting Objectives -->
    <h2>Meeting Objectives</h2>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px;">
        <div class="context-box" style="background: #e8f5e9; border-color: #c8e6c9;">
            <strong style="color: #2e7d32;">Success Definition:</strong><br>{{ success_definition }}
        </div>
        <div class="context-box">
            <strong>Strategic Alignment:</strong><br>{{ strategic_alignment }}
        </div>
    </div>

    {% for obj in objectives %}
    <div class="objective-block">
        <div class="objective-title">Objective {{ loop.index }}: {{ obj.objective }}</div>
        <div class="objective-detail">
            <strong>Context:</strong> {{ obj.context }}
        </div>
        <div class="objective-detail">
            <strong>Talking Points:</strong> {{ obj.talking_points }}
        </div>
        <div class="objective-detail">
            <strong>Asks:</strong>
            {% for ask in obj.asks %}
            <br>&nbsp;&nbsp;• {{ ask }}
            {% endfor %}
        </div>
    </div>
    {% endfor %}

    <!-- Anticipated Concerns -->
    {% if anticipated_concerns %}
    <h3>Anticipated Concerns</h3>
    {% for concern in anticipated_concerns %}
    <div class="concern-block">
        <div class="concern-title">{{ concern.concern }}</div>
        <div class="concern-detail">
            <strong>Acknowledge:</strong> {{ concern.acknowledge }}<br>
            <strong>Pivot:</strong> {{ concern.pivot }}<br>
            <strong>Elevate:</strong> {{ concern.elevate }}
        </div>
    </div>
    {% endfor %}
    {% endif %}

    <!-- Landmines -->
    {% if landmines %}
    <div class="landmine-box">
        <strong>Landmines — Do Not Touch:</strong>
        {% for mine in landmines %}
        <br>• {{ mine }}
        {% endfor %}
    </div>
    {% endif %}

    <!-- Proposed Next Steps -->
    {% if proposed_next_steps %}
    <h3>Proposed Next Steps</h3>
    <div class="next-steps-row">
        <span class="next-steps-label ns-ideal">Ideal</span>
        <div class="next-steps-content">{{ proposed_next_steps.ideal }}</div>
    </div>
    <div class="next-steps-row">
        <span class="next-steps-label ns-acceptable">Acceptable</span>
        <div class="next-steps-content">{{ proposed_next_steps.acceptable }}</div>
    </div>
    <div class="next-steps-row">
        <span class="next-steps-label ns-minimum">Minimum</span>
        <div class="next-steps-content">{{ proposed_next_steps.minimum }}</div>
    </div>
    {% endif %}

    <!-- Section 4: AWS Account Background -->
    <h2>AWS Account Background</h2>
    <div class="account-grid">
        <div class="account-cell">
            <div class="account-cell-label">Geo</div>
            <div class="account-cell-value">{{ account_background.geo }}</div>
        </div>
        <div class="account-cell">
            <div class="account-cell-label">Segment</div>
            <div class="account-cell-value">{{ account_background.segment }}</div>
        </div>
        <div class="account-cell">
            <div class="account-cell-label">Current Spend</div>
            <div class="account-cell-value">{{ account_background.current_spend }}</div>
        </div>
        <div class="account-cell">
            <div class="account-cell-label">Expected</div>
            <div class="account-cell-value">{{ account_background.expected_spend }}</div>
        </div>
        <div class="account-cell">
            <div class="account-cell-label">PPA Status</div>
            <div class="account-cell-value">{{ account_background.ppa_status }}</div>
        </div>
    </div>
    <div class="context-box">
        {{ account_background.account_summary }}
    </div>

    <!-- Section 5: Appendix -->
    <h2>Appendix</h2>
    <div class="appendix-block">
        <div class="appendix-title">A. Previous Meeting Notes</div>
        <div class="appendix-content">{{ appendix.previous_meeting_notes }}</div>
    </div>
    <div class="appendix-block">
        <div class="appendix-title">B. Customer Success Stories</div>
        <div class="appendix-content">{{ appendix.customer_success_stories }}</div>
    </div>
    <div class="appendix-block">
        <div class="appendix-title">C. Competitive Intelligence</div>
        <div class="appendix-content">{{ appendix.competitive_intelligence }}</div>
    </div>

    <!-- Footer -->
    <div class="footer">Last updated: {{ last_updated }} · INTERNAL USE ONLY</div>

</body>
</html>
