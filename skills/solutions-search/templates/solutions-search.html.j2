<!DOCTYPE html>
<html lang="zh-Hans">
<head><meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solutions Search · {{ customer_name }}</title>
<style>
  @page {
    size: A4;
    margin: 14mm 12mm 20mm 12mm;
  }
  :root {
    --ink: #0f172a;
    --ink-2: #334155;
    --muted: #64748b;
    --muted-2: #cbd5e1;
    --line: #e2e8f0;
    --line-soft: #f1f5f9;
    --paper: #ffffff;
    --page-bg: #f8fafc;
    --accent: #6750A4;
    --accent-dark: #4a3880;
    --accent-soft: #EADDFF;
    --accent-softer: #f5f0ff;
    --ok: #386A20;
    --ok-soft: #C8E6C9;
    --warn: #F57F17;
    --warn-soft: #FFF9C4;
    --bad: #B3261E;
    --bad-soft: #F9DEDC;
    --secondary: #625B71;
    --secondary-soft: #E8DEF8;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    background: var(--page-bg);
    color: var(--ink);
    font-family: "Inter", "Noto Sans SC", "Noto Sans TC", -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    font-size: 13px; line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .export-bar {
    position: sticky; top: 0; z-index: 10;
    background: #1C1B1F; color: #fff;
    padding: 10px 24px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .export-bar .brand {
    font-size: 11px; letter-spacing: 2px;
    color: #EADDFF; font-weight: 700; text-transform: uppercase;
  }
  .export-bar button {
    background: var(--accent); color: #fff; border: 0;
    border-radius: 6px; padding: 7px 14px;
    font-size: 12px; font-weight: 600; cursor: pointer;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .export-bar button:hover { background: var(--accent-dark); }
  .sheet { max-width: 820px; margin: 28px auto 56px; padding: 0 28px; }

  .head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 20px; padding: 8px 8px 20px;
  }
  .head .kicker {
    font-size: 11px; font-weight: 700; letter-spacing: 2.4px;
    text-transform: uppercase; color: var(--accent); margin-bottom: 6px;
  }
  .head h1 {
    font-size: 22px; font-weight: 700; letter-spacing: -0.3px;
    margin: 0 0 6px; color: var(--ink); line-height: 1.1;
  }
  .head .sub { font-size: 13px; color: var(--muted); }
  .head .fab {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--accent-soft); color: var(--accent-dark);
    padding: 10px 16px; border-radius: 12px;
    font-size: 12px; font-weight: 600; white-space: nowrap;
  }

  .card {
    background: var(--paper); border-radius: 12px; border: 1px solid var(--line);
    padding: 22px 24px; margin-bottom: 14px;
  }
  .card h2 {
    display: flex; align-items: center; gap: 10px;
    margin: 0 0 16px; font-size: 16px; font-weight: 600;
    color: var(--ink); letter-spacing: -0.2px;
  }
  .card h2 .ico { font-size: 18px; }

  .stat-row {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;
  }
  .stat-box {
    background: var(--line-soft); border-radius: 10px;
    padding: 14px 16px; text-align: center;
  }
  .stat-box .lab { font-size: 11px; color: var(--muted); font-weight: 500; margin-bottom: 4px; }
  .stat-box .val { font-size: 15px; color: var(--ink); font-weight: 600; }
  .stat-box .val.accent { color: var(--accent); }

  .init-header {
    display: flex; align-items: center; gap: 12px;
    padding-bottom: 12px; margin-bottom: 14px;
    border-bottom: 1px solid var(--line-soft);
  }
  .init-num {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--accent); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; flex-shrink: 0;
  }
  .init-header .title { font-size: 14px; font-weight: 600; color: var(--ink); }
  .init-header .opp { font-size: 11px; color: var(--muted); margin-top: 2px; }

  .tiles-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
    margin-bottom: 14px;
  }
  .match-tile {
    background: var(--paper); border: 1px solid var(--line);
    border-radius: 10px; padding: 12px 14px;
    border-left: 4px solid var(--accent);
  }
  .match-tile.pattern { border-left-color: var(--ok); }
  .match-tile.displacement { border-left-color: var(--warn); }
  .match-tile.inspirational { border-left-color: var(--secondary); }
  .match-tile .pill-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 6px; }
  .pill {
    display: inline-flex; align-items: center; gap: 4px;
    border-radius: 100px; padding: 2px 10px;
    font-size: 10px; font-weight: 600; white-space: nowrap;
  }
  .pill-direct { background: var(--accent-soft); color: var(--accent-dark); }
  .pill-pattern { background: var(--ok-soft); color: var(--ok); }
  .pill-displacement { background: var(--warn-soft); color: var(--warn); }
  .pill-inspirational { background: var(--secondary-soft); color: var(--secondary); }
  .pill-meta { background: var(--line-soft); color: var(--muted); }
  .match-tile h4 { margin: 0 0 4px; font-size: 12.5px; font-weight: 600; color: var(--ink); }
  .match-tile h4 a { color: var(--ink); text-decoration: none; }
  .match-tile h4 a:hover { color: var(--accent); text-decoration: underline; }
  .match-tile .desc { font-size: 11px; color: var(--ink-2); line-height: 1.5; }
  .match-tile .tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 6px; }
  .match-tile .tags span {
    font-size: 9px; background: var(--line-soft); color: var(--muted);
    padding: 2px 8px; border-radius: 100px;
  }

  .next-step {
    background: var(--accent-soft); border-radius: 10px;
    padding: 10px 14px; font-size: 12px; color: var(--accent-dark);
    display: flex; align-items: center; gap: 8px;
  }
  .next-step .label {
    font-size: 9px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase;
  }

  .gap-warn {
    background: var(--warn-soft); border-radius: 10px;
    padding: 10px 14px; font-size: 11.5px; color: var(--ink-2);
    display: flex; gap: 8px; align-items: flex-start; margin-top: 10px;
  }
  .gap-warn .ico { font-size: 14px; flex-shrink: 0; }

  .reason-note {
    background: var(--line-soft); border-radius: 8px;
    padding: 10px 14px; font-size: 11px; color: var(--ink-2);
    display: flex; gap: 8px; align-items: flex-start; margin-top: 10px;
    line-height: 1.55;
  }
  .reason-note .ico { font-size: 14px; color: var(--accent); flex-shrink: 0; margin-top: 1px; }

  .foot { margin-top: 32px; padding: 16px 8px; border-top: 1px solid var(--line); font-size: 11px; color: var(--muted); text-align: center; }

  .page-footer {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    padding: 6px 12mm;
    font-family: 'Inter', sans-serif;
    font-size: 8pt;
    color: #94a3b8;
    display: flex;
    justify-content: space-between;
  }
  @media screen { .page-footer { display: none; } }
  @media print {
    .export-bar { display: none; }
    html, body { background: #fff; }
    .sheet { margin: 0; padding: 0 16px; }
    .card h2 { page-break-after: avoid; }
    .match-tile { page-break-inside: avoid; }
    .next-step { page-break-inside: avoid; }
    .reason-note { page-break-inside: avoid; }
    .init-header { page-break-after: avoid; }
  }
</style>
</head>
<body>

<div class="export-bar">
  <div class="brand">&#x25C6; SOLUTIONS SEARCH · Solutions &#x641C;&#x7D22;&#x7ED3;&#x679C;</div>
  <button onclick="window.print()">&#x1F4C4; Export PDF</button>
</div>

<div class="sheet">

  <div class="head">
    <div>
      <div class="kicker">Solutions Search · Solutions 搜索结果</div>
      <h1>{{ customer_name }}</h1>
      <div class="sub">{{ industry }} · {{ date }} · 上游：{{ upstream_source }} · Source: ./references/</div>
    </div>
    <div class="fab">&#x1F50D; 4-step match</div>
  </div>

  <!-- Coverage Summary -->
  <div class="card">
    <h2><span class="ico">&#x1F4CA;</span>Search Coverage · 检索覆盖</h2>
    <div class="stat-row">
      <div class="stat-box">
        <div class="lab">战略倡议</div>
        <div class="val">{{ coverage_summary.initiatives_count }} · Initiatives</div>
      </div>
      <div class="stat-box">
        <div class="lab">匹配文档</div>
        <div class="val accent">{{ coverage_summary.references_count }} · References</div>
      </div>
    </div>
  </div>

  <!-- Initiatives -->
  {% for initiative in initiatives %}
  <div class="card">
    <h2><span class="ico">&#x1F6A9;</span>Initiative {{ "%02d"|format(initiative.number) }} · {{ initiative.title }}</h2>
    <div class="init-header">
      <div class="init-num">{{ initiative.number }}</div>
      <div>
        <div class="title">{{ initiative.subtitle }}</div>
        <div class="opp">潜在机会：{{ initiative.potential_opportunity }}</div>
      </div>
    </div>

    <div class="tiles-grid">
      {% for ref in initiative.references %}
      <div class="match-tile {{ ref.match_type if ref.match_type != 'direct' else '' }}">
        <div class="pill-row">
          <span class="pill pill-{{ ref.match_type }}">{% if ref.match_type == 'direct' %}&#x1F680;{% elif ref.match_type == 'pattern' %}&#x1F3D7;&#xFE0F;{% elif ref.match_type == 'displacement' %}&#x1F504;{% else %}&#x2705;{% endif %} {{ ref.match_type_label }}</span>
          <span class="pill pill-meta">{{ ref.match_strength }}</span>
          <span class="pill pill-meta">{{ ref.freshness_tier }}</span>
        </div>
        <h4><a href="{{ ref.url }}" target="_blank">{{ ref.title }}</a></h4>
        <p class="desc">{{ ref.description }}</p>
        {% if ref.tags %}
        <div class="tags">
          {% for tag in ref.tags %}
          <span>{{ tag }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <div class="next-step">
      <span class="label">&#x1F6A9; Next Step</span>
      {{ initiative.next_step }}
    </div>

    {% if initiative.coverage_gap and initiative.coverage_gap != "none" %}
    <div class="gap-warn">
      <span class="ico">&#x26A0;&#xFE0F;</span>
      <div><strong>Coverage Gap</strong> {{ initiative.coverage_gap }}</div>
    </div>
    {% endif %}
  </div>
  {% endfor %}

  <div class="foot">
    Generated by Dali · Solutions Search · {{ date }}
  </div>

</div>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('print') === '1') {
    window.addEventListener('load', () => setTimeout(() => window.print(), 400));
  }
</script>

<div class="page-footer">
  <span>Dali · Solutions Search · {{ customer_name }} · {{ date }}</span>
  <span>AWS Confidential</span>
</div>
</body></html>
