<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post-Meeting Report – {{ customer_name }} | {{ meeting_title }}</title>
    <!-- Fonts: locally-installed Inter + Noto Sans SC, with cross-platform fallbacks -->
    <style>
    /* === Tailwind Replacement — Utility Classes (zero CDN dependency) === */
        /* Layout */
        .flex { display: flex; }
        .flex-1 { flex: 1 1 0%; }
        .flex-wrap { flex-wrap: wrap; }
        .grid { display: grid; }
        .grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
        .items-center { align-items: center; }
        .items-start { align-items: flex-start; }
        .justify-between { justify-content: space-between; }
        .justify-center { justify-content: center; }

        /* Spacing */
        .gap-1 { gap: 0.25rem; }
        .gap-2 { gap: 0.5rem; }
        .gap-3 { gap: 0.75rem; }
        .gap-4 { gap: 1rem; }
        .gap-6 { gap: 1.5rem; }
        .p-2 { padding: 0.5rem; }
        .p-3 { padding: 0.75rem; }
        .p-4 { padding: 1rem; }
        .p-5 { padding: 1.25rem; }
        .p-6 { padding: 1.5rem; }
        .px-2 { padding-left: 0.5rem; padding-right: 0.5rem; }
        .px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
        .px-4 { padding-left: 1rem; padding-right: 1rem; }
        .py-1 { padding-top: 0.25rem; padding-bottom: 0.25rem; }
        .py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
        .py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
        .py-4 { padding-top: 1rem; padding-bottom: 1rem; }
        .mt-1 { margin-top: 0.25rem; }
        .mt-2 { margin-top: 0.5rem; }
        .mt-3 { margin-top: 0.75rem; }
        .mt-4 { margin-top: 1rem; }
        .mt-6 { margin-top: 1.5rem; }
        .mb-1 { margin-bottom: 0.25rem; }
        .mb-2 { margin-bottom: 0.5rem; }
        .mb-3 { margin-bottom: 0.75rem; }
        .mb-4 { margin-bottom: 1rem; }
        .ml-2 { margin-left: 0.5rem; }
        .mr-2 { margin-right: 0.5rem; }
        .mx-auto { margin-left: auto; margin-right: auto; }
        .space-y-1 > * + * { margin-top: 0.25rem; }
        .space-y-2 > * + * { margin-top: 0.5rem; }
        .space-y-3 > * + * { margin-top: 0.75rem; }
        .space-y-4 > * + * { margin-top: 1rem; }
        .space-y-6 > * + * { margin-top: 1.5rem; }

        /* Sizing */
        .w-full { width: 100%; }
        .w-1\/2 { width: 50%; }
        .w-1\/3 { width: 33.333333%; }
        .max-w-4xl { max-width: 56rem; }
        .max-w-5xl { max-width: 64rem; }
        .max-w-6xl { max-width: 72rem; }
        .min-h-screen { min-height: 100vh; }

        /* Typography */
        .font-bold { font-weight: 700; }
        .font-semibold { font-weight: 600; }
        .font-medium { font-weight: 500; }
        .font-normal { font-weight: 400; }
        .text-xs { font-size: 0.75rem; line-height: 1rem; }
        .text-sm { font-size: 0.875rem; line-height: 1.25rem; }
        .text-base { font-size: 1rem; line-height: 1.5rem; }
        .text-lg { font-size: 1.125rem; line-height: 1.75rem; }
        .text-xl { font-size: 1.25rem; line-height: 1.75rem; }
        .text-2xl { font-size: 1.5rem; line-height: 2rem; }
        .text-center { text-align: center; }
        .text-left { text-align: left; }
        .text-right { text-align: right; }
        .tracking-wider { letter-spacing: 0.05em; }
        .uppercase { text-transform: uppercase; }
        .whitespace-nowrap { white-space: nowrap; }
        .truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .leading-tight { line-height: 1.25; }
        .leading-relaxed { line-height: 1.625; }

        /* Borders & Shapes */
        .rounded { border-radius: 0.25rem; }
        .rounded-md { border-radius: 0.375rem; }
        .rounded-lg { border-radius: 0.5rem; }
        .rounded-xl { border-radius: 0.75rem; }
        .rounded-2xl { border-radius: 1rem; }
        .rounded-full { border-radius: 9999px; }
        .border { border: 1px solid var(--md-sys-color-outline-variant); }
        .border-b { border-bottom: 1px solid var(--md-sys-color-outline-variant); }
        .border-t { border-top: 1px solid var(--md-sys-color-outline-variant); }
        .border-l { border-left: 1px solid var(--md-sys-color-outline-variant); }

        /* Visibility & Overflow */
        .hidden { display: none; }
        .block { display: block; }
        .inline-block { display: inline-block; }
        .inline-flex { display: inline-flex; }
        .overflow-x-auto { overflow-x: auto; }
        .overflow-hidden { overflow: hidden; }
        .break-inside-avoid { break-inside: avoid; }

        /* Position */
        .relative { position: relative; }
        .absolute { position: absolute; }
        .top-0 { top: 0; }
        .right-0 { right: 0; }

        /* Shadow */
        .shadow-sm { box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); }
        .shadow { box-shadow: 0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1); }

        /* Table */
        table { border-collapse: collapse; }
        th, td { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid var(--md-sys-color-outline-variant); }
        th { font-weight: 600; }
        :root {
            --md-sys-color-primary: #6750A4;
            --md-sys-color-on-primary: #FFFFFF;
            --md-sys-color-primary-container: #EADDFF;
            --md-sys-color-on-primary-container: #21005D;
            --md-sys-color-secondary: #625B71;
            --md-sys-color-on-secondary: #FFFFFF;
            --md-sys-color-secondary-container: #E8DEF8;
            --md-sys-color-tertiary: #7D5260;
            --md-sys-color-tertiary-container: #FFD8E4;
            --md-sys-color-surface: #FFFBFE;
            --md-sys-color-surface-variant: #E7E0EC;
            --md-sys-color-on-surface: #1C1B1F;
            --md-sys-color-on-surface-variant: #49454F;
            --md-sys-color-outline: #79747E;
            --md-sys-color-outline-variant: #CAC4D0;
            --md-sys-color-surface-container-lowest: #FFFFFF;
            --md-sys-color-surface-container-low: #F7F2FA;
            --md-sys-color-surface-container: #F3EDF7;
            --md-sys-color-surface-container-high: #ECE6F0;
            --md-sys-color-surface-container-highest: #E6E0E9;
            --md-sys-color-error: #B3261E;
            --md-sys-color-error-container: #F9DEDC;
            --md-sys-color-success: #386A20;
            --md-sys-color-success-container: #C8E6C9;
            --md-sys-color-warning: #F57F17;
            --md-sys-color-warning-container: #FFF9C4;
        }

        * { font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Microsoft YaHei', sans-serif; }
        html { font-size: 9px; }
        body {
            font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Microsoft YaHei', sans-serif;
            font-size: 9px;
            background: var(--md-sys-color-surface);
            color: var(--md-sys-color-on-surface);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        @page {
            size: A4;
            margin: 10mm 8mm 10mm 8mm;
        }

        .md-card {
            background: var(--md-sys-color-surface-container-lowest);
            border: 1px solid var(--md-sys-color-outline-variant);
            border-radius: 16px;
            padding: 14px;
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .md-card-elevated {
            background: var(--md-sys-color-surface-container-lowest);
            border-radius: 16px;
            padding: 14px;
            box-shadow: 0 1px 3px 1px rgba(0,0,0,0.08), 0 1px 2px rgba(0,0,0,0.12);
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .md-card-filled {
            background: var(--md-sys-color-surface-container-highest);
            border: none;
            border-radius: 12px;
            padding: 12px;
        }

        .pill-badge {
            border-radius: 100px;
            padding: 2px 10px;
            font-size: 9px;
            font-weight: 500;
            letter-spacing: 0.02em;
            display: inline-flex;
            align-items: center;
            gap: 3px;
            white-space: nowrap;
        }

        .pill-sponsor { background: #C8E6C9; color: #1B5E20; }
        .pill-supporter { background: #C8E6C9; color: #1B5E20; }
        .pill-neutral { background: #FFF9C4; color: #F57F17; }
        .pill-non-supporter { background: #FFCDD2; color: #B71C1C; }
        .pill-adversary { background: #FFCDD2; color: #B71C1C; }
        .pill-champion { background: #C8E6C9; color: #1B5E20; }
        .pill-achieved { background: #C8E6C9; color: #1B5E20; }
        .pill-partial { background: #FFF9C4; color: #F57F17; }
        .pill-not-achieved { background: #FFCDD2; color: #B71C1C; }
        .pill-not_achieved { background: #FFCDD2; color: #B71C1C; }
        .pill-answered { background: #C8E6C9; color: #1B5E20; }
        .pill-unanswered { background: #FFCDD2; color: #B71C1C; }
        .pill-update { background: #E8DEF8; color: #21005D; }
        .pill-add { background: #C8E6C9; color: #1B5E20; }
        .pill-remove { background: #FFCDD2; color: #B71C1C; }
        .pill-high { background: #FFCDD2; color: #B71C1C; }
        .pill-medium { background: #FFF9C4; color: #F57F17; }
        .pill-low { background: var(--md-sys-color-surface-container-highest); color: var(--md-sys-color-on-surface-variant); }

        .section-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--md-sys-color-on-surface);
            letter-spacing: -0.01em;
            margin-bottom: 10px;
        }

        .label-large {
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 0.02em;
            color: var(--md-sys-color-on-surface-variant);
        }

        .title-medium {
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0;
        }

        .body-medium {
            font-size: 10.5px;
            font-weight: 400;
            letter-spacing: 0.01em;
            color: var(--md-sys-color-on-surface-variant);
            line-height: 1.5;
        }

        .headline-small {
            font-size: 13px;
            font-weight: 600;
            letter-spacing: -0.01em;
        }

        .display-small {
            font-size: 18px;
            font-weight: 600;
            letter-spacing: -0.02em;
        }

        .section-icon {
            font-size: 16px;
            line-height: 1;
        }

        /* Table styles */
        .pmr-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
        }
        .pmr-table th {
            font-size: 9px;
            font-weight: 500;
            color: var(--md-sys-color-on-surface-variant);
            padding: 6px 8px;
            text-align: left;
            border-bottom: 1px solid var(--md-sys-color-outline-variant);
        }
        .pmr-table td {
            padding: 6px 8px;
            color: var(--md-sys-color-on-surface-variant);
            border-bottom: 1px solid var(--md-sys-color-outline-variant);
            line-height: 1.4;
            vertical-align: top;
        }
        .pmr-table tr:last-child td {
            border-bottom: none;
        }

        @media print {
            .md-card, .md-card-elevated, .md-card-filled {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body class="min-h-screen p-4">
    <div class="max-w-6xl mx-auto space-y-4">

        <!-- Header -->
        <header class="flex items-center justify-between mb-2">
            <div>
                <p class="label-large uppercase tracking-wider" style="color: var(--md-sys-color-primary);">Post-Meeting Report</p>
                <h1 class="display-small mt-1" style="color: var(--md-sys-color-on-surface);">{{ customer_name }}</h1>
                <p class="body-medium mt-1">{{ meeting_title }}</p>
                <p class="body-medium mt-1">Related: {{ related_document }}</p>
            </div>
            <div class="text-right">
                <div class="flex items-center gap-2" style="background: var(--md-sys-color-primary-container); color: var(--md-sys-color-on-primary-container); border-radius: 16px; padding: 10px 16px; font-weight: 500; box-shadow: 0 4px 8px 3px rgba(0,0,0,0.10);">
                    <span class="section-icon">📅</span>
                    <span class="title-medium">{{ meeting_date }}</span>
                </div>
                <p class="body-medium mt-2">Recorded by: {{ recorded_by }}</p>
            </div>
        </header>

        <!-- Section 1: Outcome Assessment -->
        <section class="md-card-elevated">
            <h2 class="section-title flex items-center gap-2">
                <span class="section-icon">📊</span>
                Outcome Assessment
            </h2>
            <div class="mt-3">
                <table class="pmr-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Target Meeting Outcome</th>
                            <th>Result</th>
                            <th>Evidence & Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for outcome in outcome_results %}
                        <tr>
                            <td>{{ outcome.number }}</td>
                            <td>{{ outcome.target_outcome }}</td>
                            <td>
                                {% if outcome.result == "achieved" %}
                                <span class="pill-badge pill-achieved">✅ Achieved</span>
                                {% elif outcome.result == "partial" %}
                                <span class="pill-badge pill-partial">⚠️ Partial</span>
                                {% else %}
                                <span class="pill-badge pill-not-achieved">❌ Not Achieved</span>
                                {% endif %}
                            </td>
                            <td>{{ outcome.evidence }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if fallback_outcome_assessment %}
            <div class="mt-3 p-3 rounded-xl" style="background: var(--md-sys-color-surface-container);">
                <p class="body-medium"><strong>Fallback Outcome:</strong> {{ fallback_outcome_assessment }}</p>
            </div>
            {% endif %}

            {% if stage_progression %}
            <div class="mt-3 p-3 rounded-xl" style="background: {% if stage_progression.achieved %}var(--md-sys-color-success-container){% else %}var(--md-sys-color-warning-container){% endif %};">
                <p class="title-medium" style="color: {% if stage_progression.achieved %}var(--md-sys-color-success){% else %}var(--md-sys-color-warning){% endif %};">
                    📈 Stage Progression: {{ stage_progression.planned }}
                    {% if stage_progression.achieved %} ✅{% else %} ⚠️ Actual: {{ stage_progression.actual }}{% endif %}
                </p>
            </div>
            {% endif %}
        </section>

        <!-- Section 2: Meeting Insights -->
        <section class="md-card">
            <h2 class="section-title flex items-center gap-2">
                <span class="section-icon">💡</span>
                Meeting Insights
            </h2>

            <!-- Customer Sentiment -->
            {% if sentiment_changes %}
            <div class="mt-3">
                <p class="title-medium mb-2">Customer Sentiment Changes</p>
                <table class="pmr-table">
                    <thead>
                        <tr>
                            <th>Attendee</th>
                            <th>Before</th>
                            <th></th>
                            <th>After</th>
                            <th>Evidence</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for s in sentiment_changes %}
                        <tr>
                            <td style="color: var(--md-sys-color-on-surface); font-weight: 500;">{{ s.attendee }}</td>
                            <td><span class="pill-badge pill-{{ s.stance_before|lower|replace(' ', '-')|replace('_', '-') }}">{{ s.stance_before }}</span></td>
                            <td style="text-align: center;">→</td>
                            <td><span class="pill-badge pill-{{ s.stance_after|lower|replace(' ', '-')|replace('_', '-') }}">{{ s.stance_after }}</span></td>
                            <td>{{ s.evidence }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}

            <!-- Key Findings -->
            {% if key_findings %}
            <div class="mt-4">
                <p class="title-medium mb-2">Key Findings</p>
                <table class="pmr-table">
                    <thead>
                        <tr>
                            <th>Finding</th>
                            <th>Source</th>
                            <th>Implication</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for f in key_findings %}
                        <tr>
                            <td style="color: var(--md-sys-color-on-surface); font-weight: 500;">{{ f.finding }}</td>
                            <td>{{ f.source }}</td>
                            <td>{{ f.implication }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}

            <!-- Information Gap Check -->
            {% if info_gap_check %}
            <div class="mt-4">
                <p class="title-medium mb-2">Information Gap Check</p>
                <table class="pmr-table">
                    <thead>
                        <tr>
                            <th>Question (from Call Plan)</th>
                            <th>Status</th>
                            <th>Answer / Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for q in info_gap_check %}
                        <tr>
                            <td>{{ q.question }}</td>
                            <td>
                                <span class="pill-badge pill-{{ q.status }}">
                                    {% if q.status == "answered" %}✅ Answered{% else %}❌ Unanswered{% endif %}
                                </span>
                            </td>
                            <td>{{ q.answer_notes }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        </section>

        <!-- Section 3: What Changed — EP Update -->
        <section class="md-card-elevated">
            <h2 class="section-title flex items-center gap-2">
                <span class="section-icon">📝</span>
                What Changed — EP Update
            </h2>
            {% if ep_updates %}
            <div class="mt-3">
                <table class="pmr-table">
                    <thead>
                        <tr>
                            <th>EP Section</th>
                            <th>Change Type</th>
                            <th>What to Write</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for update in ep_updates %}
                        <tr>
                            <td style="color: var(--md-sys-color-on-surface); font-weight: 500;">{{ update.section }}</td>
                            <td><span class="pill-badge pill-{{ update.change_type|lower }}">{{ update.change_type }}</span></td>
                            <td>{{ update.what_to_write }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}

            {% if execution_log_update %}
            <div class="mt-3 p-3 rounded-xl" style="background: var(--md-sys-color-surface-container);">
                <p class="label-large mb-1">Execution Log Update</p>
                <p class="body-medium leading-relaxed">{{ execution_log_update }}</p>
            </div>
            {% endif %}

            <!-- Agent Recommendation -->
            {% if agent_recommendation %}
            <div class="mt-3 p-4 rounded-xl" style="background: var(--md-sys-color-primary-container); border-left: 4px solid var(--md-sys-color-primary);">
                <p class="title-medium mb-1" style="color: var(--md-sys-color-on-primary-container);">
                    🤖 Agent Recommendation
                </p>
                <p class="body-medium leading-relaxed" style="color: var(--md-sys-color-on-primary-container);">{{ agent_recommendation }}</p>
            </div>
            {% endif %}
        </section>

        <!-- Section 4: Next Steps — Planned vs Actual -->
        <section class="md-card">
            <h2 class="section-title flex items-center gap-2">
                <span class="section-icon">🔄</span>
                Next Steps — Planned vs Actual
            </h2>

            <!-- Comparison -->
            {% if planned_next_steps and actual_next_steps %}
            <div class="mt-3">
                <table class="pmr-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Planned (from CP)</th>
                            <th>Actual Agreed</th>
                            <th>Delta</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set max_steps = [planned_next_steps|length, actual_next_steps|length] | max %}
                        {% for i in range(max_steps) %}
                        <tr>
                            <td>{{ i + 1 }}</td>
                            <td>{% if i < planned_next_steps|length %}{{ planned_next_steps[i].step }} ({{ planned_next_steps[i].owner }}, {{ planned_next_steps[i].timeline }}){% else %}<em style="color: var(--md-sys-color-outline);">— No planned item —</em>{% endif %}</td>
                            <td>{% if i < actual_next_steps|length %}{{ actual_next_steps[i].step }} ({{ actual_next_steps[i].owner }}, {{ actual_next_steps[i].timeline }}){% else %}<em style="color: var(--md-sys-color-outline);">— Dropped —</em>{% endif %}</td>
                            <td>{% if i < actual_next_steps|length %}{{ actual_next_steps[i].delta }}{% elif i < planned_next_steps|length %}Not pursued{% endif %}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}

            <!-- Action Items -->
            {% if action_items %}
            <div class="mt-4">
                <p class="title-medium mb-2">Action Items</p>
                <table class="pmr-table">
                    <thead>
                        <tr>
                            <th>Priority</th>
                            <th>Action</th>
                            <th>Owner</th>
                            <th>ETA</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in action_items %}
                        <tr>
                            <td><span class="pill-badge pill-{{ item.priority|lower }}">{{ item.priority }}</span></td>
                            <td>{{ item.action }}</td>
                            <td>{{ item.owner }}</td>
                            <td>{{ item.eta }}</td>
                            <td>{{ item.status }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        </section>

        <!-- Section 5: Customer Recap Email -->
        {% if recap_email_points %}
        <section class="md-card-elevated" style="border-left: 4px solid var(--md-sys-color-tertiary);">
            <h2 class="section-title flex items-center gap-2">
                <span class="section-icon">✉️</span>
                Customer Recap Email — Key Points
            </h2>
            <p class="body-medium mb-2">Draft for sales review before sending:</p>
            <div class="space-y-2 mt-3">
                {% for point in recap_email_points %}
                <div class="flex items-start gap-2 p-2 rounded-lg" style="background: var(--md-sys-color-surface-container);">
                    <span style="color: var(--md-sys-color-tertiary);">✓</span>
                    <p class="body-medium">{{ point }}</p>
                </div>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        <!-- Footer -->
        <footer class="text-center py-4">
            <p class="body-medium" style="color: var(--md-sys-color-on-surface-variant);">
                Generated by Dali · Last updated: {{ last_updated }}
            </p>
        </footer>

    </div>
</body>
</html>
