<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Call Plan – {{ customer_name }} | {{ meeting_title }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { font-size: 9px; }
        body {
            font-family: 'Inter', 'Noto Sans SC', -apple-system, sans-serif;
            color: #1a1a1a;
            background: #fff;
            max-width: 820px;
            margin: 0 auto;
            padding: 20px 28px;
            line-height: 1.5;
        }

        h1 { font-size: 18px; font-weight: 700; margin-bottom: 2px; }
        h2 { font-size: 13px; font-weight: 700; color: #1a1a1a; margin: 14px 0 6px 0; padding-bottom: 3px; border-bottom: 1.5px solid #e0e0e0; }
        h3 { font-size: 11px; font-weight: 600; color: #333; margin: 10px 0 4px 0; }

        .header-meta { font-size: 10px; color: #555; margin-bottom: 14px; }
        .header-meta span { margin-right: 12px; }

        .badge {
            display: inline-block;
            font-size: 9px;
            font-weight: 600;
            padding: 1px 7px;
            border-radius: 3px;
            vertical-align: middle;
        }
        .badge-sponsor { background: #c8e6c9; color: #1b5e20; }
        .badge-supporter { background: #c8e6c9; color: #1b5e20; }
        .badge-neutral { background: #fff9c4; color: #f57f17; }
        .badge-non-supporter { background: #ffcdd2; color: #b71c1c; }
        .badge-adversary { background: #ffcdd2; color: #b71c1c; }
        .badge-champion { background: #c8e6c9; color: #1b5e20; }

        .stage-badge {
            display: inline-block;
            font-size: 9px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 3px;
            background: #e3f2fd;
            color: #1565c0;
        }

        table { width: 100%; border-collapse: collapse; font-size: 10px; margin: 4px 0 8px 0; }
        th { font-size: 9px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.3px; padding: 4px 6px; border-bottom: 1px solid #ddd; text-align: left; }
        td { padding: 4px 6px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }

        .stakeholder-card {
            border: 1px solid #e8e8e8;
            border-radius: 4px;
            padding: 8px 10px;
            margin-bottom: 6px;
        }
        .stakeholder-name { font-size: 11px; font-weight: 600; }
        .stakeholder-title { font-size: 9.5px; color: #666; }
        .stakeholder-detail { font-size: 9.5px; color: #444; margin-top: 4px; line-height: 1.45; }
        .stakeholder-detail strong { color: #333; font-weight: 600; }

        .criteria-row { display: flex; gap: 10px; margin-bottom: 5px; align-items: flex-start; }
        .criteria-label { font-size: 9px; font-weight: 700; min-width: 62px; padding: 2px 6px; border-radius: 3px; text-align: center; }
        .criteria-ideal { background: #c8e6c9; color: #1b5e20; }
        .criteria-acceptable { background: #fff9c4; color: #f57f17; }
        .criteria-minimum { background: #f5f5f5; color: #555; }
        .criteria-content { font-size: 9.5px; color: #444; flex: 1; }
        .criteria-content strong { font-weight: 600; color: #333; font-size: 9px; }

        .objection-block {
            border: 1px solid #e8e8e8;
            border-radius: 4px;
            padding: 8px 10px;
            margin-bottom: 6px;
        }
        .objection-block.disqualifier { border-left: 3px solid #e53935; }
        .objection-category { font-size: 9px; font-weight: 600; color: #666; }
        .objection-text { font-size: 10px; font-weight: 600; color: #1a1a1a; margin: 2px 0 4px 0; }
        .objection-response { font-size: 9.5px; color: #444; }
        .objection-fallback { font-size: 9px; color: #666; margin-top: 3px; padding-top: 3px; border-top: 1px dashed #e0e0e0; }

        .next-steps-section { margin-bottom: 10px; }
        .next-steps-label { font-size: 10px; font-weight: 600; color: #333; margin-bottom: 4px; }
        .next-steps-label.primary { color: #2e7d32; }
        .next-steps-label.fallback { color: #f57f17; }
        .next-steps-label.exit { color: #757575; }

        .disqual-box {
            background: #fff5f5;
            border: 1px solid #ffcdd2;
            border-radius: 4px;
            padding: 6px 10px;
            margin-top: 6px;
            font-size: 9.5px;
            color: #c62828;
        }

        .fallback-box {
            background: #fffde7;
            border: 1px solid #fff9c4;
            border-radius: 4px;
            padding: 6px 10px;
            margin-top: 6px;
            font-size: 9.5px;
            color: #5d4037;
        }

        .stage-target {
            background: #e8f5e9;
            border-radius: 4px;
            padding: 4px 10px;
            font-size: 9.5px;
            color: #2e7d32;
            font-weight: 600;
            display: inline-block;
            margin-top: 4px;
        }

        .footer { text-align: center; font-size: 9px; color: #999; margin-top: 16px; padding-top: 8px; border-top: 1px solid #eee; }

        @media print {
            body { padding: 12px 16px; }
            h2, h3, .stakeholder-card, .objection-block, .next-steps-label { break-after: avoid; }
            .stakeholder-card, .objection-block { break-inside: avoid; }
            table { break-inside: auto; }
            tr { break-inside: avoid; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div style="font-size: 9px; font-weight: 700; letter-spacing: 1.5px; color: #888; text-transform: uppercase; margin-bottom: 4px;">CALL PLAN</div>
    <h1>{{ meeting_title }}</h1>
    <div class="header-meta">
        <span><strong>Customer:</strong> {{ customer_name }}</span>
        <span><strong>Opportunity:</strong> {{ opportunity_name }}</span>
        <span><strong>Date:</strong> {{ meeting_date }} {{ meeting_time }}</span>
        <span><strong>Format:</strong> {{ meeting_format }}</span>
        {% if meeting_location %}<span><strong>Location:</strong> {{ meeting_location }}</span>{% endif %}
    </div>
    <div style="margin-bottom: 14px;">
        <span class="stage-badge">{{ opp_stage }} → {{ target_stage }}</span>
    </div>

    <!-- Section 1: Customer Attendees -->
    <h2>Customer Attendees</h2>
    {% for person in customer_attendees %}
    <div class="stakeholder-card">
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 3px;">
            <span class="stakeholder-name">{{ person.name }}</span>
            <span class="stakeholder-title">{{ person.title }}</span>
            <span class="badge badge-{{ person.stance|lower|replace(' ', '-')|replace('_', '-') }}">{{ person.stance }}</span>
            {% if person.role_in_decision %}
            <span class="badge" style="background: #e8eaf6; color: #283593;">{{ person.role_in_decision }}</span>
            {% endif %}
        </div>
        <div class="stakeholder-detail">
            <strong>Focus:</strong> {{ person.focus_priorities }}<br>
            <strong>Communication:</strong> {{ person.communication_approach }}<br>
            <strong>Our Goal:</strong> {{ person.our_goal }}
        </div>
    </div>
    {% endfor %}

    <!-- AWS Team -->
    <h3>AWS Team</h3>
    <table>
        <thead><tr><th>Name</th><th>Role</th><th>Purpose</th></tr></thead>
        <tbody>
            {% for person in aws_attendees %}
            <tr>
                <td style="font-weight: 600;">{{ person.name }}</td>
                <td>{{ person.role }}</td>
                <td>{{ person.purpose }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Section 2: Target Meeting Outcomes -->
    <h2>Target Meeting Outcomes</h2>
    <table>
        <thead><tr><th>#</th><th>Customer Perspective</th><th>Our Perspective</th></tr></thead>
        <tbody>
            {% for outcome in target_outcomes %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ outcome.customer_perspective }}</td>
                <td>{{ outcome.our_perspective }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <div class="stage-target">Stage: {{ opp_stage }} → {{ target_stage }}</div>
    {% if fallback_outcome %}
    <div class="fallback-box"><strong>Fallback:</strong> {{ fallback_outcome }}</div>
    {% endif %}

    <!-- Section 3: Success Criteria -->
    <h2>Success Criteria</h2>
    {% for tier, label in [('ideal', 'Ideal'), ('acceptable', 'Acceptable'), ('minimum', 'Minimum')] %}
    <div class="criteria-row">
        <span class="criteria-label criteria-{{ tier }}">{{ label }}</span>
        <div class="criteria-content">
            <strong>Customer:</strong> {{ success_criteria[tier].customer }}<br>
            <strong>Us:</strong> {{ success_criteria[tier].us }}
        </div>
    </div>
    {% endfor %}
    {% if disqualification_signals %}
    <div class="disqual-box">
        <strong>Disqualification Signals:</strong>
        {% for signal in disqualification_signals %}
        <br>• {{ signal }}
        {% endfor %}
    </div>
    {% endif %}

    <!-- Section 4: Information Exchange -->
    <h2>Information Exchange</h2>
    <h3>Questions to Ask</h3>
    <table>
        <thead><tr><th>Question</th><th>Target</th><th>Purpose</th></tr></thead>
        <tbody>
            {% for q in questions_to_ask %}
            <tr>
                <td>{{ q.question }}</td>
                <td style="font-weight: 600; white-space: nowrap;">{{ q.target_attendee }}</td>
                <td>{{ q.purpose }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <h3>Information to Deliver</h3>
    <table>
        <thead><tr><th>What</th><th>Format</th><th>Purpose</th></tr></thead>
        <tbody>
            {% for item in info_to_deliver %}
            <tr>
                <td style="font-weight: 600;">{{ item.what }}</td>
                <td>{{ item.format }}</td>
                <td>{{ item.purpose }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Section 5: Potential Objections & Responses -->
    <h2>Potential Objections & Responses</h2>
    {% for obj in objections %}
    <div class="objection-block {% if obj.is_disqualifier %}disqualifier{% endif %}">
        <span class="objection-category">{{ obj.category }}{% if obj.is_disqualifier %} · Potential Disqualifier{% endif %}</span>
        <div class="objection-text">{{ obj.objection }}</div>
        <div class="objection-response"><strong>Response:</strong> {{ obj.response }}</div>
        <div class="objection-fallback"><strong>Plan B:</strong> {{ obj.fallback }}</div>
    </div>
    {% endfor %}

    <!-- Section 6: Meeting Agenda -->
    <h2>Meeting Agenda</h2>
    <table>
        <thead><tr><th>Time</th><th>Topic</th><th>Owner</th><th>Purpose</th></tr></thead>
        <tbody>
            {% for item in agenda %}
            <tr>
                <td style="white-space: nowrap; font-weight: 600;">{{ item.time }}</td>
                <td style="font-weight: 600;">{{ item.topic }}</td>
                <td>{{ item.owner }}</td>
                <td>{{ item.purpose }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Section 7: Potential Next Steps -->
    <h2>Potential Next Steps</h2>

    <div class="next-steps-section">
        <div class="next-steps-label primary">If meeting goes well (primary path)</div>
        <table>
            <thead><tr><th>#</th><th>Next Step</th><th>Timeline</th><th>Owner</th><th>Purpose</th></tr></thead>
            <tbody>
                {% for step in next_steps.primary %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td style="font-weight: 600;">{{ step.step }}</td>
                    <td style="white-space: nowrap;">{{ step.timeline }}</td>
                    <td>{{ step.owner }}</td>
                    <td>{{ step.purpose }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="next-steps-section">
        <div class="next-steps-label fallback">If customer needs more time (fallback path)</div>
        <table>
            <thead><tr><th>#</th><th>Next Step</th><th>Timeline</th><th>Owner</th><th>Purpose</th></tr></thead>
            <tbody>
                {% for step in next_steps.fallback %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td style="font-weight: 600;">{{ step.step }}</td>
                    <td style="white-space: nowrap;">{{ step.timeline }}</td>
                    <td>{{ step.owner }}</td>
                    <td>{{ step.purpose }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="next-steps-section">
        <div class="next-steps-label exit">If not a fit / timing wrong (graceful exit)</div>
        <table>
            <thead><tr><th>#</th><th>Next Step</th><th>Timeline</th><th>Owner</th><th>Purpose</th></tr></thead>
            <tbody>
                {% for step in next_steps.exit %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td style="font-weight: 600;">{{ step.step }}</td>
                    <td style="white-space: nowrap;">{{ step.timeline }}</td>
                    <td>{{ step.owner }}</td>
                    <td>{{ step.purpose }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Footer -->
    <div class="footer">Last updated: {{ last_updated }}</div>

</body>
</html>
