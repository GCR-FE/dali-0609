<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Call Plan – {{ customer_name }} | {{ meeting_title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" rel="stylesheet">
    <style>
        :root {
            --md-sys-color-primary: #6750A4;
            --md-sys-color-on-primary: #FFFFFF;
            --md-sys-color-primary-container: #EADDFF;
            --md-sys-color-on-primary-container: #21005D;
            --md-sys-color-secondary: #625B71;
            --md-sys-color-on-secondary: #FFFFFF;
            --md-sys-color-secondary-container: #E8DEF8;
            --md-sys-color-tertiary: #7D5260;
            --md-sys-color-tertiary-container: #FFD8E4;
            --md-sys-color-surface: #FFFBFE;
            --md-sys-color-surface-variant: #E7E0EC;
            --md-sys-color-on-surface: #1C1B1F;
            --md-sys-color-on-surface-variant: #49454F;
            --md-sys-color-outline: #79747E;
            --md-sys-color-outline-variant: #CAC4D0;
            --md-sys-color-surface-container-lowest: #FFFFFF;
            --md-sys-color-surface-container-low: #F7F2FA;
            --md-sys-color-surface-container: #F3EDF7;
            --md-sys-color-surface-container-high: #ECE6F0;
            --md-sys-color-surface-container-highest: #E6E0E9;
            --md-sys-color-error: #B3261E;
            --md-sys-color-error-container: #F9DEDC;
            --md-sys-color-success: #386A20;
            --md-sys-color-success-container: #C8E6C9;
            --md-sys-color-warning: #F57F17;
            --md-sys-color-warning-container: #FFF9C4;
        }

        * { font-family: 'Google Sans', 'Roboto', sans-serif; }

        body {
            background-color: var(--md-sys-color-surface);
            color: var(--md-sys-color-on-surface);
        }

        .md-card {
            background: var(--md-sys-color-surface-container-lowest);
            border: 1px solid var(--md-sys-color-outline-variant);
            border-radius: 28px;
            padding: 24px;
            transition: box-shadow 0.2s ease;
        }

        .md-card:hover {
            box-shadow: 0 2px 6px 2px rgba(0,0,0,0.08), 0 1px 2px rgba(0,0,0,0.12);
        }

        .md-card-elevated {
            background: var(--md-sys-color-surface-container-low);
            border: none;
            border-radius: 28px;
            padding: 24px;
            box-shadow: 0 1px 3px 1px rgba(0,0,0,0.08), 0 1px 2px rgba(0,0,0,0.12);
            transition: box-shadow 0.2s ease;
        }

        .md-card-elevated:hover {
            box-shadow: 0 4px 8px 3px rgba(0,0,0,0.10), 0 1px 3px rgba(0,0,0,0.12);
        }

        .md-card-filled {
            background: var(--md-sys-color-surface-container-highest);
            border: none;
            border-radius: 28px;
            padding: 24px;
        }

        .pill-badge {
            border-radius: 100px;
            padding: 4px 16px;
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            white-space: nowrap;
        }

        .pill-sponsor { background: #C8E6C9; color: #1B5E20; }
        .pill-supporter { background: #C8E6C9; color: #1B5E20; }
        .pill-neutral { background: #FFF9C4; color: #F57F17; }
        .pill-non-supporter { background: #FFCDD2; color: #B71C1C; }
        .pill-adversary { background: #FFCDD2; color: #B71C1C; }
        .pill-champion { background: #C8E6C9; color: #1B5E20; }
        .pill-status-quo { background: #FFF9C4; color: #F57F17; }
        .pill-price-value { background: #FFD8E4; color: #930042; }
        .pill-capability-fit { background: #E8DEF8; color: #21005D; }
        .pill-risk-trust { background: #FFCDD2; color: #B71C1C; }
        .pill-authority-process { background: #D1C4E9; color: #311B92; }
        .pill-ideal { background: #C8E6C9; color: #1B5E20; }
        .pill-acceptable { background: #FFF9C4; color: #F57F17; }
        .pill-minimum { background: var(--md-sys-color-surface-container-highest); color: var(--md-sys-color-on-surface-variant); }

        .section-title {
            font-size: 22px;
            font-weight: 500;
            color: var(--md-sys-color-on-surface);
            letter-spacing: 0;
            margin-bottom: 16px;
        }

        .label-large {
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.1px;
            color: var(--md-sys-color-on-surface-variant);
        }

        .title-medium {
            font-size: 16px;
            font-weight: 500;
            letter-spacing: 0.15px;
        }

        .body-medium {
            font-size: 14px;
            font-weight: 400;
            letter-spacing: 0.25px;
            color: var(--md-sys-color-on-surface-variant);
        }

        .headline-small {
            font-size: 24px;
            font-weight: 400;
            letter-spacing: 0;
        }

        .display-small {
            font-size: 36px;
            font-weight: 400;
            letter-spacing: 0;
        }

        @media print {
            body { background: white; }
            .md-card, .md-card-elevated, .md-card-filled { box-shadow: none; border: 1px solid #e0e0e0; }
        }
    </style>
</head>
<body class="min-h-screen p-6 md:p-10">
    <div class="max-w-6xl mx-auto space-y-6">

        <!-- Header -->
        <header class="flex items-center justify-between mb-2">
            <div>
                <p class="label-large uppercase tracking-wider" style="color: var(--md-sys-color-primary);">Call Plan</p>
                <h1 class="display-small mt-1" style="color: var(--md-sys-color-on-surface);">{{ meeting_title }}</h1>
                <p class="body-medium mt-1">{{ customer_name }} · {{ opportunity_name }}</p>
            </div>
            <div class="md-fab flex items-center gap-2" style="background: var(--md-sys-color-primary-container); color: var(--md-sys-color-on-primary-container); border-radius: 16px; padding: 16px 24px; font-weight: 500; box-shadow: 0 4px 8px 3px rgba(0,0,0,0.10);">
                <span class="material-symbols-outlined">event</span>
                <span class="text-lg font-medium">{{ meeting_date }}</span>
            </div>
        </header>

        <!-- Section 1: Meeting Details -->
        <section class="md-card-elevated">
            <h2 class="section-title flex items-center gap-2">
                <span class="material-symbols-outlined" style="color: var(--md-sys-color-primary);">info</span>
                Meeting Details
            </h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
                <div class="md-card-filled text-center p-5">
                    <p class="label-large">Date & Time</p>
                    <p class="title-medium mt-1">{{ meeting_date }}<br>{{ meeting_time }}</p>
                </div>
                <div class="md-card-filled text-center p-5">
                    <p class="label-large">Format</p>
                    <p class="title-medium mt-1">{{ meeting_format }}</p>
                </div>
                <div class="md-card-filled text-center p-5">
                    <p class="label-large">Location</p>
                    <p class="title-medium mt-1">{{ meeting_location }}</p>
                </div>
                <div class="md-card-filled text-center p-5">
                    <p class="label-large">Stage Progression</p>
                    <p class="title-medium mt-1" style="color: var(--md-sys-color-primary);">{{ opp_stage }} → {{ target_stage }}</p>
                </div>
            </div>

            <!-- Customer Attendees -->
            <div class="mt-6">
                <p class="label-large mb-3">Customer Attendees</p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {% for person in customer_attendees %}
                    <div class="md-card-filled p-5 flex flex-col gap-3" style="border-radius: 20px;">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="title-medium">{{ person.name }}</p>
                                <p class="body-medium">{{ person.title }}</p>
                            </div>
                            <span class="pill-badge pill-{{ person.stance|lower|replace(' ', '-')|replace('_', '-') }}">{{ person.stance }}</span>
                            {% if person.role_in_decision %}
                            <span class="pill-badge" style="background: var(--md-sys-color-tertiary-container); color: var(--md-sys-color-on-tertiary-container);">{{ person.role_in_decision }}</span>
                            {% endif %}
                        </div>
                        <div class="space-y-2">
                            <div class="p-3 rounded-xl" style="background: var(--md-sys-color-surface-container);">
                                <p class="body-medium"><strong>Focus & Priorities:</strong> {{ person.focus_priorities }}</p>
                            </div>
                            <div class="p-3 rounded-xl" style="background: var(--md-sys-color-surface-container);">
                                <p class="body-medium"><strong>Communication:</strong> {{ person.communication_approach }}</p>
                            </div>
                            <div class="p-3 rounded-xl" style="background: var(--md-sys-color-primary-container); opacity: 0.8;">
                                <p class="body-medium" style="color: var(--md-sys-color-on-primary-container);"><strong>Our Goal:</strong> {{ person.our_goal }}</p>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <!-- AWS Attendees -->
            <div class="mt-6">
                <p class="label-large mb-3">AWS Team</p>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <th class="label-large py-3 px-2">Name</th>
                                <th class="label-large py-3 px-2">Role</th>
                                <th class="label-large py-3 px-2">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for person in aws_attendees %}
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ person.name }}</td>
                                <td class="body-medium py-3 px-2">{{ person.role }}</td>
                                <td class="body-medium py-3 px-2">{{ person.purpose }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Section 2: Target Meeting Outcomes -->
        <section class="md-card">
            <h2 class="section-title flex items-center gap-2">
                <span class="material-symbols-outlined" style="color: var(--md-sys-color-primary);">target</span>
                Target Meeting Outcomes
            </h2>
            <div class="overflow-x-auto mt-4">
                <table class="w-full text-left">
                    <thead>
                        <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                            <th class="label-large py-3 px-2">#</th>
                            <th class="label-large py-3 px-2">Customer Perspective</th>
                            <th class="label-large py-3 px-2">Our Perspective</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for outcome in target_outcomes %}
                        <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                            <td class="body-medium py-3 px-2">{{ loop.index }}</td>
                            <td class="body-medium py-3 px-2">{{ outcome.customer_perspective }}</td>
                            <td class="body-medium py-3 px-2">{{ outcome.our_perspective }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="mt-4 p-4 rounded-2xl" style="background: var(--md-sys-color-primary-container);">
                <p class="body-medium" style="color: var(--md-sys-color-on-primary-container);"><strong>Stage Progression Target:</strong> {{ opp_stage }} → {{ target_stage }}</p>
            </div>
            {% if fallback_outcome %}
            <div class="mt-3 p-4 rounded-2xl" style="background: var(--md-sys-color-warning-container);">
                <p class="body-medium" style="color: #5D4037;"><strong>Fallback Outcome:</strong> {{ fallback_outcome }}</p>
            </div>
            {% endif %}
        </section>

        <!-- Section 3: Success Criteria -->
        <section class="md-card-elevated">
            <h2 class="section-title flex items-center gap-2">
                <span class="material-symbols-outlined" style="color: var(--md-sys-color-primary);">verified</span>
                Success Criteria
            </h2>
            <div class="space-y-4 mt-4">
                {% for tier, label in [('ideal', 'Ideal'), ('acceptable', 'Acceptable'), ('minimum', 'Minimum')] %}
                <div class="p-4 rounded-2xl flex items-start gap-4" style="background: var(--md-sys-color-surface-container);">
                    <span class="pill-badge pill-{{ tier }}">{{ label }}</span>
                    <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <p class="label-large">Customer</p>
                            <p class="body-medium mt-1">{{ success_criteria[tier].customer }}</p>
                        </div>
                        <div>
                            <p class="label-large">Us</p>
                            <p class="body-medium mt-1">{{ success_criteria[tier].us }}</p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>

            {% if disqualification_signals %}
            <div class="mt-6 p-4 rounded-2xl" style="background: var(--md-sys-color-error-container);">
                <p class="title-medium mb-2" style="color: var(--md-sys-color-error);">⚠️ Disqualification Signals</p>
                <ul class="space-y-1">
                    {% for signal in disqualification_signals %}
                    <li class="body-medium flex items-start gap-2">
                        <span class="material-symbols-outlined text-base mt-0.5" style="color: var(--md-sys-color-error);">close</span>
                        {{ signal }}
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        </section>

        <!-- Section 4: Information Exchange -->
        <section class="md-card">
            <h2 class="section-title flex items-center gap-2">
                <span class="material-symbols-outlined" style="color: var(--md-sys-color-primary);">swap_horiz</span>
                Information Exchange
            </h2>

            <!-- Questions to Ask -->
            <div class="mt-4">
                <p class="title-medium mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base" style="color: var(--md-sys-color-primary);">help</span>
                    Questions to Ask
                </p>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <th class="label-large py-3 px-2">Question</th>
                                <th class="label-large py-3 px-2">Target Attendee</th>
                                <th class="label-large py-3 px-2">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for q in questions_to_ask %}
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <td class="body-medium py-3 px-2">{{ q.question }}</td>
                                <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ q.target_attendee }}</td>
                                <td class="body-medium py-3 px-2">{{ q.purpose }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Information to Deliver -->
            <div class="mt-6">
                <p class="title-medium mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base" style="color: var(--md-sys-color-primary);">present_to_all</span>
                    Information to Deliver
                </p>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <th class="label-large py-3 px-2">What</th>
                                <th class="label-large py-3 px-2">Format</th>
                                <th class="label-large py-3 px-2">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in info_to_deliver %}
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ item.what }}</td>
                                <td class="body-medium py-3 px-2">{{ item.format }}</td>
                                <td class="body-medium py-3 px-2">{{ item.purpose }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Section 5: Potential Objections & Responses -->
        <section class="md-card-elevated">
            <h2 class="section-title flex items-center gap-2">
                <span class="material-symbols-outlined" style="color: var(--md-sys-color-primary);">shield</span>
                Potential Objections & Responses
            </h2>
            <div class="space-y-4 mt-4">
                {% for obj in objections %}
                <div class="p-5 rounded-2xl" style="background: var(--md-sys-color-surface-container); {% if obj.is_disqualifier %}border-left: 4px solid var(--md-sys-color-error);{% endif %}">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="pill-badge pill-{{ obj.category|lower|replace('/', '-')|replace(' ', '-') }}">{{ obj.category }}</span>
                        {% if obj.is_disqualifier %}
                        <span class="pill-badge" style="background: var(--md-sys-color-error-container); color: var(--md-sys-color-error);">⚠️ Potential Disqualifier</span>
                        {% endif %}
                    </div>
                    <p class="title-medium mb-2" style="color: var(--md-sys-color-on-surface);">{{ obj.objection }}</p>
                    <div class="space-y-2 mt-3">
                        <div class="p-3 rounded-xl" style="background: var(--md-sys-color-surface-container-lowest);">
                            <p class="body-medium"><strong>Response:</strong> {{ obj.response }}</p>
                        </div>
                        <div class="p-3 rounded-xl" style="background: var(--md-sys-color-warning-container); opacity: 0.8;">
                            <p class="body-medium" style="color: #5D4037;"><strong>Plan B:</strong> {{ obj.fallback }}</p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </section>

        <!-- Section 6: Meeting Agenda -->
        <section class="md-card" style="border-left: 4px solid var(--md-sys-color-primary);">
            <h2 class="section-title flex items-center gap-2">
                <span class="material-symbols-outlined" style="color: var(--md-sys-color-primary);">schedule</span>
                Meeting Agenda
            </h2>
            <div class="overflow-x-auto mt-4">
                <table class="w-full text-left">
                    <thead>
                        <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                            <th class="label-large py-3 px-2">Time</th>
                            <th class="label-large py-3 px-2">Topic</th>
                            <th class="label-large py-3 px-2">Owner</th>
                            <th class="label-large py-3 px-2">Purpose</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in agenda %}
                        <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                            <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ item.time }}</td>
                            <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ item.topic }}</td>
                            <td class="body-medium py-3 px-2">{{ item.owner }}</td>
                            <td class="body-medium py-3 px-2">{{ item.purpose }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Section 7: Potential Next Steps -->
        <section class="md-card-elevated">
            <h2 class="section-title flex items-center gap-2">
                <span class="material-symbols-outlined" style="color: var(--md-sys-color-primary);">arrow_forward</span>
                Potential Next Steps
            </h2>

            <!-- Primary Path -->
            <div class="mt-4">
                <p class="title-medium mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base" style="color: var(--md-sys-color-success);">check_circle</span>
                    If meeting goes well (primary path)
                </p>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <th class="label-large py-3 px-2">#</th>
                                <th class="label-large py-3 px-2">Proposed Next Step</th>
                                <th class="label-large py-3 px-2">Timeline</th>
                                <th class="label-large py-3 px-2">Owner</th>
                                <th class="label-large py-3 px-2">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for step in next_steps.primary %}
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <td class="body-medium py-3 px-2">{{ loop.index }}</td>
                                <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ step.step }}</td>
                                <td class="body-medium py-3 px-2">{{ step.timeline }}</td>
                                <td class="body-medium py-3 px-2">{{ step.owner }}</td>
                                <td class="body-medium py-3 px-2">{{ step.purpose }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Fallback Path -->
            <div class="mt-6">
                <p class="title-medium mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base" style="color: var(--md-sys-color-warning);">schedule</span>
                    If customer needs more time (fallback path)
                </p>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <th class="label-large py-3 px-2">#</th>
                                <th class="label-large py-3 px-2">Proposed Next Step</th>
                                <th class="label-large py-3 px-2">Timeline</th>
                                <th class="label-large py-3 px-2">Owner</th>
                                <th class="label-large py-3 px-2">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for step in next_steps.fallback %}
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <td class="body-medium py-3 px-2">{{ loop.index }}</td>
                                <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ step.step }}</td>
                                <td class="body-medium py-3 px-2">{{ step.timeline }}</td>
                                <td class="body-medium py-3 px-2">{{ step.owner }}</td>
                                <td class="body-medium py-3 px-2">{{ step.purpose }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Graceful Exit -->
            <div class="mt-6">
                <p class="title-medium mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-base" style="color: var(--md-sys-color-on-surface-variant);">door_open</span>
                    If not a fit / timing wrong (graceful exit)
                </p>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <th class="label-large py-3 px-2">#</th>
                                <th class="label-large py-3 px-2">Proposed Next Step</th>
                                <th class="label-large py-3 px-2">Timeline</th>
                                <th class="label-large py-3 px-2">Owner</th>
                                <th class="label-large py-3 px-2">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for step in next_steps.exit %}
                            <tr class="border-b" style="border-color: var(--md-sys-color-outline-variant);">
                                <td class="body-medium py-3 px-2">{{ loop.index }}</td>
                                <td class="body-medium py-3 px-2 font-medium" style="color: var(--md-sys-color-on-surface);">{{ step.step }}</td>
                                <td class="body-medium py-3 px-2">{{ step.timeline }}</td>
                                <td class="body-medium py-3 px-2">{{ step.owner }}</td>
                                <td class="body-medium py-3 px-2">{{ step.purpose }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="text-center py-4">
            <p class="body-medium">Last updated: {{ last_updated }}</p>
        </footer>

    </div>
</body>
</html>
